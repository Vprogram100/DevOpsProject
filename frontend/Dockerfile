

# 1. משתמשים בתמונת בסיס רשמית של Node.js
FROM node:18-alpine

# 2. מגדירים את תיקיית העבודה בתוך הקונטיינר
WORKDIR /app

# 3. מעתיקים את קבצי הגדרות החבילות
COPY package*.json ./

# 4. מתקינים את כל התלויות (החבילות של ריאקט)
RUN npm install

# 5. מעתיקים את שאר קבצי הפרויקט (קוד המקור של הריאקט)
COPY . .

# 6. חושפים את הפורט שבו ריאקט רץ בדרך כלל (3000)
EXPOSE 3000

# 7. פקודה להרצת השרת של ריאקט במצב פיתוח
CMD ["npm", "start"]